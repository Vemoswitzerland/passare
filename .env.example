# ── SUPABASE ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── STRIPE ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_LIGHT=price_...
STRIPE_PRICE_PRO=price_...

# ── RESEND (Email) ────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@passare.ch

# ── CLAUDE AI ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ZEFIX API (Handelsregister) ───────────────
ZEFIX_API_BASE=https://www.zefix.ch/ZefixREST/api/v1

# ── BETA GATE ─────────────────────────────────
BETA_ACCESS_CODE=passare2026
BETA_GATE_ENABLED=true

# ── APP CONFIG ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://passare.ch
